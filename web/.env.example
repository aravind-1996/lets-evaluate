# =============================================================================
# Let's Evaluate — deployment configuration
# Copy to .env.local and customize for your organization.
# =============================================================================

# --- Database & auth (required) ---
DATABASE_URL=postgresql://user:password@host:5432/dbname
AUTH_SECRET=change-me-use-openssl-rand-base64-32
AUTH_URL=https://evaluate.yourcompany.com

# --- OpenAI ---
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
OPENAI_ANALYSIS_MODEL=gpt-4o

# =============================================================================
# Organization identity — one org per deployment
# =============================================================================
ORG_SLUG=kanini
ORG_NAME=KANINI

# Restrict sign-up and login to a single email domain (optional)
ALLOWED_EMAIL_DOMAIN=kanini.com
# Client-side mirror for username → email display in forms (match ALLOWED_EMAIL_DOMAIN)
NEXT_PUBLIC_EMAIL_DOMAIN=kanini.com
# Public org name for client components (defaults to ORG_NAME)
NEXT_PUBLIC_ORG_NAME=KANINI

# =============================================================================
# Branding & white-label
# =============================================================================
NEXT_PUBLIC_APP_TITLE=Let's Evaluate
NEXT_PUBLIC_APP_TITLE_ACCENT=Evaluate
NEXT_PUBLIC_APP_DESCRIPTION=AI-assisted technical hiring. People first.
NEXT_PUBLIC_BRAND_TAGLINE=Intellect · Energy · Integrity
NEXT_PUBLIC_BRAND_COPYRIGHT=© 2026 KANINI Software Solutions

# Optional logo / favicon (URL or path under /public)
# NEXT_PUBLIC_BRAND_LOGO_URL=/logo.svg
# NEXT_PUBLIC_BRAND_FAVICON_URL=/favicon.ico

# Public app URL (used in links; AUTH_URL is preferred in production)
# NEXT_PUBLIC_APP_URL=https://evaluate.yourcompany.com

# --- Color palette (hex) — omit any to keep KANINI defaults ---
# Primary brand color (buttons, links, highlights)
NEXT_PUBLIC_BRAND_PRIMARY=#23b0e6
NEXT_PUBLIC_BRAND_PRIMARY_DARK=#1c8db8
# NEXT_PUBLIC_BRAND_PRIMARY_SOFT=#e3f4fb

# Accent (success states, positive indicators)
NEXT_PUBLIC_BRAND_ACCENT=#61a229
# NEXT_PUBLIC_BRAND_ACCENT_SOFT=#e8f3dc

# Warning / attention
NEXT_PUBLIC_BRAND_WARNING=#e87722
# NEXT_PUBLIC_BRAND_WARNING_SOFT=#fce8d6

# Surfaces & text
NEXT_PUBLIC_BRAND_NAVY=#1a2b3c
NEXT_PUBLIC_BRAND_CREAM=#fdf8f3
NEXT_PUBLIC_BRAND_CREAM_2=#f5efe8
NEXT_PUBLIC_BRAND_INK=#292929
NEXT_PUBLIC_BRAND_INK_SOFT=#5c5c5c
NEXT_PUBLIC_BRAND_INK_FAINT=#9a9a9a

# =============================================================================
# Resume storage (optional)
# =============================================================================
RESUME_STORAGE_PROVIDER=local
# S3_BUCKET=
# S3_REGION=auto
# S3_ENDPOINT=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=

# =============================================================================
# Microsoft Entra ID SSO (optional)
# =============================================================================
# AZURE_AD_CLIENT_ID=
# AZURE_AD_CLIENT_SECRET=
# AZURE_AD_TENANT_ID=
# AZURE_AD_ADMIN_GROUPS=
# AZURE_AD_TA_GROUPS=
# AZURE_AD_INTERVIEWER_GROUPS=
# NEXT_PUBLIC_AZURE_SSO_ENABLED=true

# =============================================================================
# Migration (one-time)
# =============================================================================
# LEGACY_DATABASE_URL=
